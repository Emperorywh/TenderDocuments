# 强类型配置环境变量示例（A-013）。
# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，密钥不得进入仓库
# （SPEC.md 第 12.3 节）。未列默认值的变量为必填，缺失时进程启动即失败退出。

# ---- 数据库（PostgreSQL）----
DATABASE_URL=postgresql+psycopg://tender:tender@127.0.0.1:5432/tender

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- 对象存储（S3 兼容 / MinIO）----
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minio-access-key
S3_SECRET_KEY=minio-secret-key
S3_BUCKET=tender
S3_REGION=us-east-1

# ---- DeepSeek（外部模型）----
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-with-real-key
DEEPSEEK_FAST_MODEL=replace-with-fast-model-id
DEEPSEEK_STRONG_MODEL=replace-with-strong-model-id
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_CONCURRENCY=4
DEEPSEEK_PROJECT_BUDGET=100
DEEPSEEK_JSON_MODE=true

# ---- 文件与项目限额（可配置，max_project_pages 为业务硬限制）----
MAX_FILE_BYTES=104857600
MAX_FILES_PER_PROJECT=100
MAX_PROJECT_BYTES=1073741824
MAX_PROJECT_PAGES=500

# ---- 对象授权 URL 有效期（秒）----
PRESIGNED_URL_TTL_SECONDS=900

# ---- 运行开关：发布前可置 false 停止接收新分析运行 ----
ACCEPT_NEW_ANALYSIS=true

# ---- 日志级别 ----
LOG_LEVEL=INFO
